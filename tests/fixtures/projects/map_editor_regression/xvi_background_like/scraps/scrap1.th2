encoding utf-8
##XTHERION## xth_me_area_adjust -64 -64 164 64
##XTHERION## xth_me_area_zoom_to 100
##XTHERION## xth_me_image_insert {0 1 1.0} {0 {}} data/template_p.xvi 0 {}

scrap scrap1 -projection plan
  point 0 0 station -name 1@survey1
  point 100 0 station -name 2@survey1
  line wall -id line1
    -10 16
    12 28 36 30 58 18
    72 12 90 10 110 14
  endline
endscrap
